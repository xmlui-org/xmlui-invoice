<Component 
    name="StatusBadge"
    var.statusColors="{{
        draft: { background: '$color-warn-500', label: '$color-surface' },
        sent: { background: '$color-primary-500', label: '$color-surface' },
        paid: { background: '$color-success-500', label: '$color-surface' }
    }}"
>
    <Badge 
        value="{$props.status}" 
        colorMap="{statusColors}" 
        variant="pill" 
    />
</Component>
